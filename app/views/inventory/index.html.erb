<div class="inventory-page">
  <header class="inventory-header">
    <div>
      <p>AI-Link Inventario</p>
      <h1>Inventario</h1>
      <span>Administra productos, ventas, stock e imágenes exportadas por Haru.</span>
    </div>

    <%= link_to "Volver al panel", dashboard_index_path, class: "inventory-back" %>
  </header>

  <section class="inventory-haru-card">
    <div class="inventory-haru-face">
      <div class="inventory-haru-eye"></div>
      <div class="inventory-haru-eye"></div>
    </div>

    <div>
      <h2>Haru</h2>
      <p id="inventoryHaruMessage">
        Aquí puedes revisar los productos que exportaste desde el apartado de inteligencia artificial.
      </p>
    </div>
  </section>

  <section class="inventory-stats">
    <div class="inventory-stat-card">
      <span>Productos</span>
      <strong><%= @total_products %></strong>
    </div>

    <div class="inventory-stat-card">
      <span>Stock total</span>
      <strong><%= @total_stock || 0 %></strong>
    </div>

    <div class="inventory-stat-card">
      <span>Stock bajo</span>
      <strong><%= @low_stock %></strong>
    </div>
  </section>

  <section class="inventory-products">
    <% if @products.any? %>
      <% @products.each do |product| %>
        <article class="inventory-product-card">
          <div class="inventory-product-image">
            <% if product.image.attached? %>
              <%= image_tag product.image %>
            <% else %>
              <span>Sin imagen</span>
            <% end %>
          </div>

          <div class="inventory-product-info">
            <h3><%= product.name %></h3>
            <p><%= product.description.presence || "Sin descripción registrada." %></p>

            <div class="inventory-product-data">
              <span>Precio: $<%= product.price || 0 %></span>

              <% if product.quantity.to_i <= 0 %>
                <span class="inventory-danger">Agotado</span>
              <% elsif product.quantity.to_i <= 5 %>
                <span class="inventory-warning">Stock bajo: <%= product.quantity %></span>
              <% else %>
                <span>Cantidad: <%= product.quantity %></span>
              <% end %>
            </div>
          </div>

          <div class="inventory-actions">
            <%= form_with url: inventory_sold_path, method: :post, local: true, class: "inventory-sold-form" do %>
              <%= hidden_field_tag :product_id, product.id %>
              <%= number_field_tag :sold_quantity, 1, min: 1, class: "inventory-number" %>
              <%= submit_tag "Vendido", class: "inventory-btn inventory-btn-blue" %>
            <% end %>

            <%= form_with url: inventory_sold_out_path, method: :post, local: true do %>
              <%= hidden_field_tag :product_id, product.id %>
              <%= submit_tag "Agotar", class: "inventory-btn inventory-btn-red" %>
            <% end %>

            <%= form_with url: inventory_delete_path, method: :post, local: true do %>
              <%= hidden_field_tag :product_id, product.id %>
              <%= submit_tag "Eliminar", class: "inventory-btn inventory-btn-dark" %>
            <% end %>
          </div>
        </article>
      <% end %>
    <% else %>
      <div class="inventory-empty">
        <h2>No hay productos todavía</h2>
        <p>Sube una imagen en el apartado de IA, analízala con Haru y expórtala al inventario.</p>
        <%= link_to "Ir a IA", ai_index_path %>
      </div>
    <% end %>
  </section>

  <nav class="inventory-bottom-nav">
    <%= link_to "Inicio", dashboard_index_path %>
    <%= link_to "Campañas", campaigns_index_path %>
    <%= link_to "Inventario", inventory_index_path %>
    <%= link_to "IA", ai_index_path %>
  </nav>
</div>

<script>
document.addEventListener("turbo:load", function () {
  const message = document.getElementById("inventoryHaruMessage");

  if (!message) return;

  const messages = [
    "Aquí puedes revisar los productos que exportaste desde el apartado de inteligencia artificial.",
    "Si un producto se vende, registra la cantidad vendida para actualizar el stock.",
    "Cuando un producto ya no esté disponible, puedes marcarlo como agotado.",
    "Los productos con pocas unidades aparecerán como stock bajo.",
    "Más adelante podré ayudarte a recomendar qué productos promocionar primero."
  ];

  let index = 0;

  setInterval(function () {
    index = (index + 1) % messages.length;
    message.style.opacity = "0";

    setTimeout(function () {
      message.textContent = messages[index];
      message.style.opacity = "1";
    }, 300);
  }, 3000);
});
</script>