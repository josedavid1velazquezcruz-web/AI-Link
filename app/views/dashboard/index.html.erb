<div class="app-layout">
  <aside class="sidebar">
    <h2>AI-Link</h2>

    <nav>
      <%= link_to " Inicio", dashboard_index_path %>
      <%= link_to " Campañas", campaigns_path %>
      <%= link_to " Inventario", inventory_index_path %>
      <%= link_to " IA", ai_index_path %>
      <%= button_to "Cerrar sesión", destroy_user_session_path, method: :delete, class: "logout-btn" %>
    </nav>
  </aside>

  <main class="dashboard-content">
    <section class="welcome-card">
      <h1>Bienvenido a AI-Link Marketing Suite</h1>
      <p>
        Esta plataforma te ayuda a organizar productos, crear campañas de marketing
        y generar ideas con inteligencia artificial.
      </p>
    </section>

    <section class="steps-grid">
      <div class="step-card">
        <span>1</span>
        <h3>Registra tus productos</h3>
        <p>Agrega productos o servicios para tenerlos listos en tu inventario.</p>
      </div>

      <div class="step-card">
        <span>2</span>
        <h3>Crea campañas</h3>
        <p>Diseña campañas para promocionar tus productos en redes sociales.</p>
      </div>

      <div class="step-card">
        <span>3</span>
        <h3>Usa la IA</h3>
        <p>Genera ideas, textos publicitarios y propuestas de contenido.</p>
      </div>

      <div class="step-card">
        <span>4</span>
        <h3>Revisa resultados</h3>
        <p>Consulta tu panel para ver tus campañas y administrar tu negocio.</p>
      </div>
    </section>

    <section class="assistant-card">
      <div class="mascot"></div>
      <div>
        <h2>Hola, soy tu asistente AI-Link</h2>
        <p>¿Con qué quieres empezar?</p>

        <div class="assistant-actions">
          <%= link_to "Crear campaña", campaigns_path, class: "primary-btn" %>
          <%= link_to "Ver inventario", inventory_index_path, class: "secondary-btn" %>
          <%= link_to "Usar IA", ai_index_path, class: "secondary-btn" %>
        </div>
      </div>
    </section>
  </main>

  <nav class="mobile-bottom-nav">
    <%= link_to dashboard_index_path do %>
      <span></span>
      <small>Inicio</small>
    <% end %>

    <%= link_to campaigns_path do %>
      <span></span>
      <small>Campañas</small>
    <% end %>

    <%= link_to inventory_index_path do %>
      <span></span>
      <small>Inventario</small>
    <% end %>

    <%= link_to ai_index_path do %>
      <span></span>
      <small>IA</small>
    <% end %>
  </nav>
</div>