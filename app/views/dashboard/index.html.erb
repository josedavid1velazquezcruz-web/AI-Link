<div class="control-page">
  <header class="control-header">
    <div>
      <p>AI-Link Panel Principal</p>
      <h1>Centro de control</h1>
      <span>Gestiona campañas, inventario e inteligencia artificial desde un solo lugar.</span>
    </div>

    <%= button_to "Cerrar sesión", destroy_user_session_path, method: :delete, class: "control-logout" %>
  </header>

  <section class="control-haru-card">
    <div class="control-haru-face">
      <div class="control-haru-eye"></div>
      <div class="control-haru-eye"></div>
    </div>

    <div>
      <h2>Haru</h2>
      <p id="controlHaruMessage">
        Bienvenido. Desde aquí puedes controlar toda tu plataforma AI-Link.
      </p>
    </div>
  </section>

  <section class="control-stats">
    <div class="control-stat-card">
      <span>Campañas</span>
      <strong><%= @total_campaigns %></strong>
    </div>

    <div class="control-stat-card">
      <span>Activas</span>
      <strong><%= @active_campaigns %></strong>
    </div>

    <div class="control-stat-card">
      <span>Productos</span>
      <strong><%= @total_products %></strong>
    </div>

    <div class="control-stat-card">
      <span>Stock bajo</span>
      <strong><%= @low_stock %></strong>
    </div>
  </section>

  <section class="control-actions">
    <%= link_to "Crear campaña", campaigns_index_path %>
    <%= link_to "Ver inventario", inventory_index_path %>
    <%= link_to "Abrir Haru IA", ai_index_path %>
  </section>

  <section class="control-grid">
    <div class="control-panel">
      <h2>Campañas recientes</h2>

      <% if @recent_campaigns.any? %>
        <% @recent_campaigns.each do |campaign| %>
          <div class="control-list-item">
            <strong><%= campaign.name %></strong>
            <span><%= campaign.status.presence || "Sin estado" %></span>
          </div>
        <% end %>
      <% else %>
        <p class="control-empty-text">Todavía no tienes campañas creadas.</p>
      <% end %>
    </div>

    <div class="control-panel">
      <h2>Productos recientes</h2>

      <% if @recent_products.any? %>
        <% @recent_products.each do |product| %>
          <div class="control-list-item">
            <strong><%= product.name %></strong>
            <span>Cantidad: <%= product.quantity || 0 %></span>
          </div>
        <% end %>
      <% else %>
        <p class="control-empty-text">Todavía no tienes productos en inventario.</p>
      <% end %>
    </div>
  </section>

  <section class="control-steps">
    <h2>Ruta recomendada por Haru</h2>

    <div class="control-steps-grid">
      <div>
        <strong>Paso 1</strong>
        <p>Sube una imagen en IA y deja que Haru prepare un producto.</p>
      </div>

      <div>
        <strong>Paso 2</strong>
        <p>Exporta el producto al inventario y revisa su stock.</p>
      </div>

      <div>
        <strong>Paso 3</strong>
        <p>Crea una campaña para promocionar ese producto.</p>
      </div>
    </div>
  </section>

  <nav class="control-bottom-nav">
    <%= link_to "Inicio", dashboard_index_path %>
    <%= link_to "Campañas", campaigns_index_path %>
    <%= link_to "Inventario", inventory_index_path %>
    <%= link_to "IA", ai_index_path %>
  </nav>
</div>

<script>
document.addEventListener("turbo:load", function () {
  const message = document.getElementById("controlHaruMessage");

  if (!message) return;

  const messages = [
    "Bienvenido. Desde aquí puedes controlar toda tu plataforma AI-Link.",
    "Te recomiendo empezar subiendo una imagen en el apartado de IA.",
    "Después puedes exportar productos al inventario.",
    "Cuando tengas productos, crea campañas para promocionarlos.",
    "Si el stock está bajo, revisa tu inventario antes de crear nuevas promociones.",
    "Puedo ayudarte a transformar productos en campañas de marketing."
  ];

  let index = 0;

  setInterval(function () {
    index = (index + 1) % messages.length;
    message.style.opacity = "0";

    setTimeout(function () {
      message.textContent = messages[index];
      message.style.opacity = "1";
    }, 300);
  }, 3000);
});
</script>