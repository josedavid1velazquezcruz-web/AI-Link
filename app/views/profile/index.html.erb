<div class="profile-page">

  <header class="profile-header">
    <div>
      <p>AI-Link Perfil</p>
      <h1>Mi Perfil</h1>
      <span>
        Administra tu cuenta, personaliza Haru y consulta tu actividad.
      </span>
    </div>

    <%= link_to "Volver al panel",
    dashboard_index_path,
    class: "profile-back" %>
  </header>

  <section class="profile-haru-card">

    <div class="profile-haru-face">
      <div class="profile-haru-eye"></div>
      <div class="profile-haru-eye"></div>
    </div>

    <div>
      <h2>Haru</h2>

      <p id="profileHaruMessage">
        Bienvenido. Aquí puedes personalizar tu experiencia dentro de AI-Link.
      </p>
    </div>

  </section>

  <section class="profile-stats">

    <div class="profile-stat-card">
      <span>Campañas</span>
      <strong><%= @total_campaigns %></strong>
    </div>

    <div class="profile-stat-card">
      <span>Productos</span>
      <strong><%= @total_products %></strong>
    </div>

    <div class="profile-stat-card">
      <span>Stock</span>
      <strong><%= @total_stock || 0 %></strong>
    </div>

  </section>

  <section class="profile-main">

    <div class="profile-card">

      <h2>Información personal</h2>

      <% if current_user.avatar.attached? %>

        <%= image_tag current_user.avatar,
        class: "profile-avatar" %>

      <% else %>

        <div class="profile-avatar-placeholder">
          H
        </div>

      <% end %>

      <%= form_with url: profile_update_path,
      method: :post,
      multipart: true,
      local: true do %>

        <div class="profile-field">
          <label>Nombre de usuario</label>

          <%= text_field_tag :username,
          current_user.username,
          class: "profile-input" %>
        </div>

        <div class="profile-field">
          <label>Correo electrónico</label>

          <input
            type="email"
            value="<%= current_user.email %>"
            disabled
            class="profile-input"
          >
        </div>

        <div class="profile-field">
          <label>Foto de perfil</label>

          <%= file_field_tag :avatar,
          accept: "image/*",
          class: "profile-input" %>
        </div>

        <%= submit_tag "Guardar cambios",
        class: "profile-save-btn" %>

      <% end %>

    </div>

    <div class="profile-card">

      <h2>Configuración de Haru</h2>

      <div class="profile-setting">
        <strong>Modo actual</strong>
        <p>Asistente de marketing digital</p>
      </div>

      <div class="profile-setting">
        <strong>Funciones activas</strong>
        <p>
          Inventario, campañas, análisis de imágenes e inteligencia artificial.
        </p>
      </div>

      <div class="profile-setting">
        <strong>Próximamente</strong>
        <p>
          GPT, Gemini, Claude, DeepSeek y memoria avanzada.
        </p>
      </div>

      <%= button_to "Cambiar contraseña",
      edit_user_registration_path,
      method: :get,
      class: "profile-password-btn" %>

    </div>

  </section>

  <nav class="profile-bottom-nav">
    <%= link_to "Inicio", dashboard_index_path %>
    <%= link_to "Campañas", campaigns_index_path %>
    <%= link_to "Inventario", inventory_index_path %>
    <%= link_to "IA", ai_index_path %>
  </nav>

</div>

<script>
document.addEventListener("turbo:load", function () {

  const message =
    document.getElementById("profileHaruMessage");

  if (!message) return;

  const messages = [
    "Bienvenido. Aquí puedes personalizar tu experiencia dentro de AI-Link.",
    "Tu perfil almacena la información principal de tu cuenta.",
    "Más adelante podré recordar campañas y productos favoritos.",
    "Pronto podrás elegir diferentes personalidades para Haru.",
    "La inteligencia artificial se integrará directamente desde este perfil."
  ];

  let index = 0;

  setInterval(function () {

    index = (index + 1) % messages.length;

    message.style.opacity = "0";

    setTimeout(function () {

      message.textContent = messages[index];

      message.style.opacity = "1";

    }, 300);

  }, 3000);

});
</script>