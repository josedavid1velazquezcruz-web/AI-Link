<div style="
  width:100vw;
  min-height:100vh;
  background:
    linear-gradient(rgba(10,10,30,0.92), rgba(10,10,30,0.96)),
    radial-gradient(circle at top left, #ff00ff 0%, transparent 30%),
    radial-gradient(circle at bottom right, #00ffff 0%, transparent 30%),
    #050510;
  color:white;
  font-family:Arial;
  display:flex;
">

  <!-- SIDEBAR -->

  <div style="
    width:270px;
    background:rgba(17,24,39,0.92);
    padding:30px;
    border-right:1px solid #7c3aed;
  ">

    <h1 style="font-size:32px; color:#00ffff;">
      AI-Link
    </h1>

    <br><br>

    <a href="/dashboard/index" style="color:white; text-decoration:none;">
      <p> inicio</p>
    </a>

    <br>

    <a href="/campaigns/index" style="color:white; text-decoration:none;">
      <p> Campañas</p>
    </a>

    <br>

    <a href="/inventory/index" style="color:white; text-decoration:none;">
      <p> Inventario</p>
    </a>

    <br>

    <a href="/ai/index" style="color:white; text-decoration:none;">
      <p> IA Marketing</p>
    </a>

    <br>

    <a href="/profile/index" style="color:#00ffff; text-decoration:none;">
      <p> Mi Perfil</p>
    </a>

  </div>

  <!-- CONTENIDO -->

  <div style="
    flex:1;
    padding:50px;
  ">

    <h1 style="
      font-size:50px;
      color:#ff00ff;
    ">
      Mi Perfil
    </h1>

    <p style="
      color:#ccc;
      margin-top:10px;
      font-size:18px;
    ">
      Administra tu cuenta y configuración.
    </p>

    <br><br>

    <div style="
      background:rgba(255,255,255,0.08);
      padding:40px;
      border-radius:25px;
      border:1px solid #00ffff;
      max-width:700px;
    ">

      <!-- FOTO -->

      <div style="margin-bottom:30px;">

        <% if current_user.avatar.attached? %>

          <%= image_tag current_user.avatar, style: "
            width:140px;
            height:140px;
            border-radius:50%;
            object-fit:cover;
            border:4px solid #ff00ff;
          " %>

        <% else %>

          <div style="
            width:140px;
            height:140px;
            border-radius:50%;
            background:#7c3aed;
            display:flex;
            align-items:center;
            justify-content:center;
            font-size:60px;
          ">
            👤
          </div>

        <% end %>

      </div>

      <!-- FORM -->

      <form action="/profile/update" method="post" enctype="multipart/form-data">

        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>

        <label style="font-size:18px;">
          Nombre de usuario
        </label>

        <br><br>

        <input
          type="text"
          name="username"
          value="<%= current_user.username %>"
          style="
            width:100%;
            padding:15px;
            border:none;
            border-radius:12px;
            margin-bottom:25px;
            font-size:16px;
          "
        >

        <label style="font-size:18px;">
          Correo electrónico
        </label>

        <br><br>

        <input
          type="email"
          value="<%= current_user.email %>"
          disabled
          style="
            width:100%;
            padding:15px;
            border:none;
            border-radius:12px;
            margin-bottom:25px;
            background:#ddd;
          "
        >

        <label style="font-size:18px;">
          Foto de perfil
        </label>

        <br><br>

        <input
          type="file"
          name="avatar"
          accept="image/*"
          style="
            margin-bottom:30px;
          "
        >

        <br>

        <button
          type="submit"
          style="
            background:#2563eb;
            color:white;
            padding:16px 30px;
            border:none;
            border-radius:12px;
            font-size:18px;
            cursor:pointer;
          "
        >
          Guardar Cambios
        </button>

      </form>

      <br><br>

      <!-- CAMBIAR CONTRASEÑA -->

      <%= button_to "Cambiar Contraseña",
      edit_user_registration_path,
      method: :get,
      style: "
        background:#ff00ff;
        color:white;
        border:none;
        padding:16px 30px;
        border-radius:12px;
        font-size:18px;
        cursor:pointer;
      " %>

    </div>

  </div>

</div>