<div class="haru-ai-page">
  <header class="haru-ai-header">
    <div>
      <p>AI-Link Inteligencia Artificial</p>
      <h1>Haru</h1>
      <span>Tu asistente para analizar imágenes, generar ideas y preparar campañas.</span>
    </div>

    <%= link_to "Volver al panel", dashboard_index_path, class: "haru-ai-back" %>
  </header>

  <main class="haru-ai-layout">
    <section class="haru-ai-assistant">
      <button class="haru-ai-face-button" id="haruOpenTools" type="button">
        <div class="haru-ai-face haru-state-normal" id="haruFace">
          <div class="haru-ai-eye"></div>
          <div class="haru-ai-eye"></div>
        </div>
      </button>

      <div class="haru-ai-status">
        <h2>Haru</h2>
        <p id="haruStatusText">Estoy lista para ayudarte. Toca mi rostro o elige una acción.</p>
      </div>
    </section>

    <section class="haru-ai-chat">
      <div class="haru-chat-window" id="haruChatWindow">
        <div class="haru-message haru-message-bot">
          Hola, soy Haru. Puedo ayudarte a analizar una imagen, preparar un producto y generar ideas de campaña.
        </div>

        <% if @image_result.present? %>
          <div class="haru-message haru-message-bot">
            <%= @image_result %>
          </div>

          <div class="haru-message haru-message-bot">
            Producto preparado: <%= @generated_title %>
          </div>

          <div class="haru-message haru-message-bot">
            Descripción generada: <%= @generated_description %>
          </div>
        <% end %>
      </div>

      <div class="haru-action-grid">
        <button type="button" class="haru-action-btn" data-action="image">Analizar imagen</button>
        <button type="button" class="haru-action-btn" data-action="ad">Generar anuncio</button>
        <button type="button" class="haru-action-btn" data-action="campaign">Idea de campaña</button>
        <button type="button" class="haru-action-btn" data-action="clear">Limpiar chat</button>
      </div>
    </section>
  </main>

  <section class="haru-tools-panel <%= 'active' if @image_result.present? %>" id="haruToolsPanel">
    <div class="haru-tools-card">
      <div class="haru-tools-header">
        <div>
          <p>Herramientas de Haru</p>
          <h2>Analizar producto</h2>
        </div>

        <button type="button" id="haruCloseTools" class="haru-close-btn">Cerrar</button>
      </div>

      <%= form_with url: ai_analyze_image_path, method: :post, multipart: true, local: true, class: "haru-upload-form" do |f| %>
        <div class="haru-upload-grid">
          <label class="haru-upload-option">
            <strong>Tomar foto</strong>
            <span>Abre la cámara del celular para capturar un producto.</span>
            <%= f.file_field :image, accept: "image/*", capture: "environment", class: "haru-image-input" %>
          </label>

          <label class="haru-upload-option">
            <strong>Subir foto</strong>
            <span>Selecciona una imagen desde tu dispositivo.</span>
            <%= f.file_field :image, accept: "image/*", class: "haru-image-input" %>
          </label>
        </div>

        <div class="haru-preview" id="haruPreview">
          <p>No has seleccionado ninguna imagen todavía.</p>
          <img id="haruPreviewImage" alt="Vista previa de imagen">
        </div>

        <div class="haru-extra-fields">
          <%= f.text_field :name, placeholder: "Nombre del producto", class: "haru-input" %>
          <%= f.text_area :description, placeholder: "Descripción breve", class: "haru-input", rows: 3 %>
          <%= f.number_field :price, placeholder: "Precio", class: "haru-input", step: "0.01" %>
          <%= f.number_field :quantity, placeholder: "Cantidad", class: "haru-input" %>
        </div>

        <%= f.submit "Analizar con Haru", class: "haru-submit-btn", id: "haruAnalyzeSubmit" %>
      <% end %>

      <% if @image_result.present? %>
        <div class="haru-result-card">
          <h3>Resultado de Haru</h3>

          <p><%= @image_result %></p>

          <div class="haru-result-data">
            <p><strong>Nombre:</strong> <%= @generated_title %></p>
            <p><strong>Descripción:</strong> <%= @generated_description %></p>
            <p><strong>Precio:</strong> <%= @generated_price %></p>
            <p><strong>Cantidad:</strong> <%= @generated_quantity %></p>
          </div>

          <%= form_with url: ai_export_product_path, method: :post, local: true do %>
            <%= hidden_field_tag :name, @generated_title %>
            <%= hidden_field_tag :description, @generated_description %>
            <%= hidden_field_tag :price, @generated_price %>
            <%= hidden_field_tag :quantity, @generated_quantity %>
            <%= hidden_field_tag :image_blob_signed_id, @image_blob_signed_id %>

            <%= submit_tag "Exportar al inventario", class: "haru-submit-btn" %>
          <% end %>
        </div>
      <% end %>
    </div>
  </section>

  <nav class="haru-ai-bottom-nav">
    <%= link_to "Inicio", dashboard_index_path %>
    <%= link_to "Campañas", campaigns_index_path %>
    <%= link_to "Inventario", inventory_index_path %>
    <%= link_to "IA", ai_index_path %>
  </nav>
</div>

<script>
document.addEventListener("turbo:load", function () {
  const toolsPanel = document.getElementById("haruToolsPanel");
  const openTools = document.getElementById("haruOpenTools");
  const closeTools = document.getElementById("haruCloseTools");
  const statusText = document.getElementById("haruStatusText");
  const chatWindow = document.getElementById("haruChatWindow");
  const face = document.getElementById("haruFace");
  const imageInputs = document.querySelectorAll(".haru-image-input");
  const preview = document.getElementById("haruPreview");
  const previewImage = document.getElementById("haruPreviewImage");
  const actionButtons = document.querySelectorAll(".haru-action-btn");
  const analyzeSubmit = document.getElementById("haruAnalyzeSubmit");

  function addMessage(text, type) {
    if (!chatWindow) return;

    const message = document.createElement("div");
    message.className = "haru-message " + type;
    message.textContent = text;
    chatWindow.appendChild(message);
    chatWindow.scrollTop = chatWindow.scrollHeight;
  }

  function setHaruState(text, state = "normal") {
    if (!statusText || !face) return;

    statusText.textContent = text;

    face.classList.remove(
      "haru-state-normal",
      "haru-state-thinking",
      "haru-state-analyzing",
      "haru-state-success",
      "haru-state-error"
    );

    face.classList.add("haru-state-" + state);
  }

  function simulateHaruResponse(text) {
    setHaruState("Estoy pensando una respuesta...", "thinking");

    setTimeout(function () {
      addMessage(text, "haru-message-bot");
      setHaruState("Lista para ayudarte con el siguiente paso.", "normal");
    }, 1200);
  }

  if (openTools) {
    openTools.addEventListener("click", function () {
      toolsPanel.classList.add("active");
      addMessage("Quiero analizar una imagen.", "haru-message-user");
      simulateHaruResponse("Puedes tomar una foto o subir una imagen. Después presiona Analizar con Haru.");
    });
  }

  if (closeTools) {
    closeTools.addEventListener("click", function () {
      toolsPanel.classList.remove("active");
      setHaruState("Panel cerrado. Puedes tocarme de nuevo cuando quieras.", "normal");
    });
  }

  actionButtons.forEach(function (button) {
    button.addEventListener("click", function () {
      const action = button.dataset.action;

      if (action === "image") {
        toolsPanel.classList.add("active");
        addMessage("Quiero analizar una imagen.", "haru-message-user");
        simulateHaruResponse("Perfecto. Sube una foto o toma una imagen del producto.");
      }

      if (action === "ad") {
        addMessage("Quiero generar un anuncio.", "haru-message-user");
        setHaruState("Generando idea de anuncio...", "thinking");

        setTimeout(function () {
          addMessage("Anuncio sugerido: Presenta tu producto con una frase directa, una ventaja principal y una invitación a comprar.", "haru-message-bot");
          setHaruState("Anuncio generado.", "success");
        }, 1600);
      }

      if (action === "campaign") {
        addMessage("Quiero una idea de campaña.", "haru-message-user");
        setHaruState("Preparando idea de campaña...", "thinking");

        setTimeout(function () {
          addMessage("Idea de campaña: publica una imagen del producto, explica su beneficio principal y ofrece una promoción limitada.", "haru-message-bot");
          setHaruState("Idea de campaña lista.", "success");
        }, 1600);
      }

      if (action === "clear") {
        chatWindow.innerHTML = "";
        addMessage("Hola, soy Haru. Empezamos de nuevo. ¿Qué quieres hacer?", "haru-message-bot");
        setHaruState("Chat reiniciado. Estoy lista para ayudarte.", "normal");
      }
    });
  });

  imageInputs.forEach(function (input) {
    input.addEventListener("change", function () {
      const file = input.files[0];

      if (!file) {
        setHaruState("No se seleccionó ninguna imagen.", "error");
        return;
      }

      const imageUrl = URL.createObjectURL(file);
      previewImage.src = imageUrl;
      preview.classList.add("has-image");

      addMessage("Ya seleccioné una imagen.", "haru-message-user");
      setHaruState("Imagen lista. Presiona Analizar con Haru para continuar.", "success");
    });
  });

  if (analyzeSubmit) {
    analyzeSubmit.addEventListener("click", function () {
      addMessage("Analiza esta imagen.", "haru-message-user");
      setHaruState("Enviando imagen para análisis...", "analyzing");
    });
  }
});
</script>