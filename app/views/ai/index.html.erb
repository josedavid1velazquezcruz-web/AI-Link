<div class="ai-page">
  <header class="ai-header">
    <div>
      <p>AI-Link Inteligencia Artificial</p>
      <h1>Asistente Haru</h1>
      <span>Analiza imágenes, genera ideas y prepara contenido para tus campañas.</span>
    </div>

    <%= link_to "Volver al panel", dashboard_index_path, class: "ai-back-btn" %>
  </header>

  <section class="ai-hero">
    <div class="ai-haru-area">
      <button class="ai-haru-button" id="haru-open-panel" type="button">
        <div class="ai-haru-face">
          <div class="ai-haru-eye"></div>
          <div class="ai-haru-eye"></div>
        </div>
      </button>

      <div class="ai-haru-message">
        <h2>Haru</h2>
        <p id="haru-ai-message">
          Hola, soy Haru. Tócame para iniciar un análisis con imagen.
        </p>
      </div>
    </div>

    <div class="ai-info-card">
      <h3>¿Qué puedes hacer aquí?</h3>
      <p>
        Este apartado está preparado para analizar fotos de productos, generar ideas
        de contenido y ayudarte a crear campañas usando diferentes modelos de IA.
      </p>
    </div>
  </section>

  <section class="ai-actions-panel" id="haru-actions-panel">
    <div class="ai-actions-card">
      <div class="ai-actions-header">
        <div>
          <p>Opciones de Haru</p>
          <h2>Elige cómo quieres empezar</h2>
        </div>

        <button type="button" id="haru-close-panel" class="ai-close-btn">Cerrar</button>
      </div>

      <div class="ai-upload-grid">
        <label class="ai-upload-option">
          <span>Tomar foto</span>
          <small>Usa la cámara del dispositivo para capturar una imagen.</small>
          <input type="file" accept="image/*" capture="environment" class="ai-hidden-input">
        </label>

        <label class="ai-upload-option">
          <span>Subir foto</span>
          <small>Selecciona una imagen guardada en tu celular o computadora.</small>
          <input type="file" accept="image/*" class="ai-hidden-input" id="ai-image-input">
        </label>
      </div>

      <div class="ai-preview-box" id="ai-preview-box">
        <p>Cuando selecciones una imagen, aparecerá aquí la vista previa.</p>
        <img id="ai-preview-image" alt="Vista previa de imagen">
      </div>
    </div>
  </section>

  <section class="ai-future-grid">
    <div>
      <h3>Análisis de imagen</h3>
      <p>Haru podrá reconocer productos, colores, estilo visual y oportunidades de mejora.</p>
    </div>

    <div>
      <h3>Generación de anuncios</h3>
      <p>Después del análisis, se podrán crear textos para redes, campañas y promociones.</p>
    </div>

    <div>
      <h3>Sistema de varias IAs</h3>
      <p>Más adelante podremos cambiar automáticamente entre modelos si un token se acaba.</p>
    </div>
  </section>

  <nav class="ai-bottom-nav">
    <%= link_to "Inicio", dashboard_index_path %>
    <%= link_to "Campañas", campaigns_index_path %>
    <%= link_to "Inventario", inventory_index_path %>
    <%= link_to "IA", ai_index_path %>
  </nav>
</div>

<script>
document.addEventListener("turbo:load", function () {
  const openButton = document.getElementById("haru-open-panel");
  const closeButton = document.getElementById("haru-close-panel");
  const panel = document.getElementById("haru-actions-panel");
  const message = document.getElementById("haru-ai-message");
  const imageInputs = document.querySelectorAll(".ai-hidden-input");
  const previewImage = document.getElementById("ai-preview-image");
  const previewBox = document.getElementById("ai-preview-box");

  if (openButton && panel) {
    openButton.addEventListener("click", function () {
      panel.classList.add("active");
      if (message) {
        message.textContent = "Elige si quieres tomar una foto o subir una imagen.";
      }
    });
  }

  if (closeButton && panel) {
    closeButton.addEventListener("click", function () {
      panel.classList.remove("active");
      if (message) {
        message.textContent = "Tócame cuando quieras iniciar otro análisis.";
      }
    });
  }

  imageInputs.forEach(function (input) {
    input.addEventListener("change", function () {
      const file = input.files[0];
      if (!file) return;

      const imageUrl = URL.createObjectURL(file);
      previewImage.src = imageUrl;
      previewBox.classList.add("has-image");

      if (message) {
        message.textContent = "Imagen cargada. Después conectaremos aquí el análisis con IA.";
      }
    });
  });
});
</script>