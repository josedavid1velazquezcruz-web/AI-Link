<script>
document.addEventListener("turbo:load", function () {

  const assistantMessage = document.getElementById("assistant-message");

  if (!assistantMessage) return;

  const messages = [
    "Bienvenido a AI-Link. Crea tu cuenta para comenzar.",
    "Podrás administrar campañas de marketing desde un solo lugar.",
    "Organiza productos y servicios dentro de tu inventario.",
    "Genera contenido utilizando inteligencia artificial.",
    "Analiza tus estrategias desde tu panel principal.",
    "Estoy listo para ayudarte durante tu experiencia en la plataforma."
  ];

  let currentMessage = 0;

  setInterval(() => {
    currentMessage++;

    if (currentMessage >= messages.length) {
      currentMessage = 0;
    }

    assistantMessage.style.opacity = "0";

    setTimeout(() => {
      assistantMessage.textContent = messages[currentMessage];
      assistantMessage.style.opacity = "1";
    }, 300);

  }, 3000);

});
</script>
