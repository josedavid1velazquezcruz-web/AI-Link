<div class="auth-mascot-box">
  <div class="auth-mascot">
    <div class="auth-mascot-eye"></div>
    <div class="auth-mascot-eye"></div>
  </div>

  <div class="auth-mascot-message" id="assistant-message">
    Bienvenido a AI-Link. Crea tu cuenta para comenzar.
  </div>
</div>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "auth-form" }) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div class="auth-field">
    <%= f.label :email, "Correo electrónico" %>
    <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "correo@ejemplo.com" %>
  </div>

  <div class="auth-field">
    <%= f.label :password, "Contraseña" %>
    <%= f.password_field :password, autocomplete: "new-password", placeholder: "Mínimo 6 caracteres" %>
  </div>

  <div class="auth-field">
    <%= f.label :password_confirmation, "Confirmar contraseña" %>
    <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Repite tu contraseña" %>
  </div>

  <%= f.submit "Crear cuenta", class: "auth-submit" %>
<% end %>

<div class="auth-extra-links">
  <%= link_to "Ya tengo cuenta", new_user_session_path %>
  <%= link_to "Volver al inicio", root_path %>
</div>
