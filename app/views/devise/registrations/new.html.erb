<div class="ai-auth-page">
  <div class="ai-auth-glow ai-auth-glow-one"></div>
  <div class="ai-auth-glow ai-auth-glow-two"></div>

  <section class="ai-auth-card">
    <div class="ai-auth-brand">
      <p>AI-Link Marketing Digital</p>
      <h1>Crear cuenta</h1>
      <span>Regístrate para comenzar a crear campañas y administrar tu contenido.</span>
    </div>

    <div class="ai-auth-assistant">
      <div class="ai-assistant-face">
        <div class="ai-assistant-eye"></div>
        <div class="ai-assistant-eye"></div>
      </div>

      <div class="ai-assistant-text" id="assistant-message">
        Bienvenido a AI-Link. Crea tu cuenta para comenzar.
      </div>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "ai-auth-form" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div class="ai-auth-field">
        <%= f.label :email, "Correo electrónico" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "correo@ejemplo.com" %>
      </div>

      <div class="ai-auth-field">
        <%= f.label :password, "Contraseña" %>
        <%= f.password_field :password, autocomplete: "new-password", placeholder: "Mínimo 6 caracteres" %>
      </div>

      <div class="ai-auth-field">
        <%= f.label :password_confirmation, "Confirmar contraseña" %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "Repite tu contraseña" %>
      </div>

      <%= f.submit "Crear cuenta", class: "ai-auth-submit" %>
    <% end %>

    <div class="ai-auth-links">
      <%= link_to "Ya tengo cuenta", new_user_session_path %>
      <%= link_to "Volver al inicio", root_path %>
    </div>
  </section>
</div>

<script>
document.addEventListener("turbo:load", function () {
  const assistantMessage = document.getElementById("assistant-message");
  if (!assistantMessage) return;

  const messages = [
    "Bienvenido a AI-Link. Crea tu cuenta para comenzar.",
    "Podrás administrar campañas de marketing desde un solo lugar.",
    "Organiza productos y servicios dentro de tu inventario.",
    "Genera contenido utilizando inteligencia artificial.",
    "Analiza tus estrategias desde tu panel principal.",
    "Estoy listo para ayudarte durante tu experiencia en la plataforma."
  ];

  let currentMessage = 0;

  setInterval(function () {
    currentMessage = (currentMessage + 1) % messages.length;
    assistantMessage.style.opacity = "0";

    setTimeout(function () {
      assistantMessage.textContent = messages[currentMessage];
      assistantMessage.style.opacity = "1";
    }, 300);
  }, 3000);
});
</script>