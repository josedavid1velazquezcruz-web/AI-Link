<div style="
  width:100vw;
  min-height:100vh;
  background:
    linear-gradient(rgba(10,10,30,0.92), rgba(10,10,30,0.96)),
    radial-gradient(circle at top left, #ff00ff 0%, transparent 30%),
    radial-gradient(circle at bottom right, #00ffff 0%, transparent 30%),
    #050510;
  color:white;
  font-family:Arial;
  display:flex;
  justify-content:center;
  align-items:center;
">

  <div style="
    background:rgba(255,255,255,0.08);
    padding:50px;
    border-radius:25px;
    border:1px solid #00ffff;
    width:550px;
    box-shadow:0 0 30px rgba(0,255,255,0.2);
  ">

    <h1 style="
      font-size:45px;
      color:#ff00ff;
      margin-bottom:10px;
    ">
      Cambiar Contraseña
    </h1>

    <p style="
      color:#ccc;
      margin-bottom:35px;
    ">
      Actualiza la seguridad de tu cuenta.
    </p>

    <%= form_for(resource,
    as: resource_name,
    url: registration_path(resource_name),
    html: { method: :put }) do |f| %>

      <div style="margin-bottom:25px;">

        <label>
          Nueva contraseña
        </label>

        <br><br>

        <%= f.password_field :password,
        autocomplete: "new-password",
        style: "
          width:100%;
          padding:15px;
          border:none;
          border-radius:12px;
          font-size:16px;
        " %>

      </div>

      <div style="margin-bottom:25px;">

        <label>
          Confirmar contraseña
        </label>

        <br><br>

        <%= f.password_field :password_confirmation,
        autocomplete: "new-password",
        style: "
          width:100%;
          padding:15px;
          border:none;
          border-radius:12px;
          font-size:16px;
        " %>

      </div>

      <div style="margin-bottom:30px;">

        <label>
          Contraseña actual
        </label>

        <br><br>

        <%= f.password_field :current_password,
        autocomplete: "current-password",
        style: "
          width:100%;
          padding:15px;
          border:none;
          border-radius:12px;
          font-size:16px;
        " %>

      </div>

      <button
        type="submit"
        style="
          background:#2563eb;
          color:white;
          padding:16px 30px;
          border:none;
          border-radius:12px;
          font-size:18px;
          cursor:pointer;
          width:100%;
        "
      >
        Guardar Nueva Contraseña
      </button>

    <% end %>

    <br><br>

    <a href="/profile/index" style="
      color:#00ffff;
      text-decoration:none;
    ">
      ← Volver al Perfil
    </a>

  </div>

</div>