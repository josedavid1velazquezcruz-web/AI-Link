<div class="auth-cyber-page">
  <div class="auth-orb auth-orb-one"></div>
  <div class="auth-orb auth-orb-two"></div>

  <section class="auth-cyber-panel">
    <div class="auth-brand">
      <p>AI-Link Marketing Digital</p>
      <h1>Iniciar sesión</h1>
      <span>Accede a tu panel para administrar campañas, inventario y contenido inteligente.</span>
    </div>

    <div class="auth-mascot-box">
      <div class="auth-mascot">
        <div class="auth-mascot-eye"></div>
        <div class="auth-mascot-eye"></div>
      </div>
      <div class="auth-mascot-message">
        Hola. Ingresa tus datos para continuar.
      </div>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <div class="auth-field">
        <%= f.label :email, "Correo electrónico" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "correo@ejemplo.com" %>
      </div>

      <div class="auth-field">
        <%= f.label :password, "Contraseña" %>
        <%= f.password_field :password, autocomplete: "current-password", placeholder: "Ingresa tu contraseña" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="auth-check">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "Recordarme" %>
        </div>
      <% end %>

      <%= f.submit "Entrar", class: "auth-submit" %>
    <% end %>

    <div class="auth-extra-links">
      <%= link_to "Crear cuenta", new_user_registration_path %>
      <%= link_to "Volver al inicio", root_path %>
    </div>
  </section>
</div>