<div class="auth-page">
  <div class="auth-info">
    <h1>Bienvenido a AI-Link</h1>
    <p>
      Administra campañas, inventario y genera ideas de marketing con ayuda de inteligencia artificial.
    </p>

    <div class="auth-steps">
      <div>Registra tus productos</div>
      <div>Crea campañas</div>
      <div>Genera ideas con IA</div>
    </div>
  </div>

  <div class="auth-card">
    <h2>Iniciar sesión</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="field">
        <%= f.label :email, "Correo electrónico" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email" %>
      </div>

      <div class="field">
        <%= f.label :password, "Contraseña" %>
        <%= f.password_field :password, autocomplete: "current-password" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="remember-field">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "Recordarme" %>
        </div>
      <% end %>

      <%= f.submit "Entrar", class: "auth-btn" %>
    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>