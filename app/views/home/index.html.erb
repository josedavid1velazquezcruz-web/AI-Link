<div class="cyber-home">
  <header class="cyber-header">
    <div class="cyber-title">
      <p>Marketing digital inteligente</p>
      <h1>AI-Link</h1>
    </div>

    <div class="cyber-mascot">
      <div class="mascot-face">
        <div class="mascot-eye"></div>
        <div class="mascot-eye"></div>
      </div>

      <div class="mascot-message">
        Hola, soy Haru. Estoy listo para ayudarte a comenzar.
      </div>
    </div>
  </header>

  <main class="cyber-center">
    <section class="cyber-card">
      <h2>Administra tu marketing en un solo lugar</h2>
      <p>
        Crea campañas, organiza tu inventario y genera ideas de contenido con inteligencia artificial.
      </p>

      <div class="cyber-actions">
        <%= link_to "Iniciar sesión", new_user_session_path, class: "cyber-btn primary" %>
        <%= link_to "Registrarse", new_user_registration_path, class: "cyber-btn secondary" %>
      </div>
    </section>
  </main>
</div>