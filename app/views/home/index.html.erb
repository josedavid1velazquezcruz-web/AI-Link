<div class="home-page">

  <header class="topbar">
    <div class="logo">
      <h1>AI-Link</h1>
      <p>Marketing Digital Inteligente</p>
    </div>

    <nav>
      <%= link_to "Inicio", root_path %>
      <%= link_to "Iniciar Sesión", new_user_session_path %>
      <%= link_to "Registrarse", new_user_registration_path %>
    </nav>
  </header>

  <section class="hero">
    <h2>Impulsa tu negocio con inteligencia artificial</h2>

    <p>
      Gestiona campañas, inventario y contenido publicitario desde una sola plataforma.
    </p>

    <div class="hero-buttons">
      <%= link_to "Comenzar", new_user_registration_path, class: "primary-btn" %>
      <%= link_to "Iniciar Sesión", new_user_session_path, class: "secondary-btn" %>
    </div>
  </section>

  <section class="guide-section">
    <h2>¿Cómo funciona?</h2>

    <div class="guide-grid">

      <div class="guide-card">
        <h3>Paso 1</h3>
        <p>Regístrate y crea tu cuenta.</p>
      </div>

      <div class="guide-card">
        <h3>Paso 2</h3>
        <p>Agrega productos o servicios a tu inventario.</p>
      </div>

      <div class="guide-card">
        <h3>Paso 3</h3>
        <p>Crea campañas de marketing para promocionar tu negocio.</p>
      </div>

      <div class="guide-card">
        <h3>Paso 4</h3>
        <p>Utiliza la inteligencia artificial para generar ideas y contenido.</p>
      </div>

    </div>
  </section>

  <section class="assistant-section">
    <div class="assistant-card">
      <h2>Asistente AI-Link</h2>

      <p>
        Bienvenido. Estoy aquí para ayudarte a comenzar.
      </p>

      <div class="assistant-options">
        <%= link_to "Crear una cuenta", new_user_registration_path, class: "assistant-btn" %>
        <%= link_to "Iniciar sesión", new_user_session_path, class: "assistant-btn" %>
      </div>
    </div>
  </section>

</div>