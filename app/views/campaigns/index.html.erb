<div class="campaigns-page">
  <header class="campaigns-header">
    <div>
      <p>AI-Link Campañas</p>
      <h1>Campañas</h1>
      <span>Administra campañas privadas para promocionar tus productos y servicios.</span>
    </div>

    <%= link_to "Volver al panel", dashboard_index_path, class: "campaigns-back" %>
  </header>

  <section class="campaigns-haru-card">
    <div class="campaigns-haru-face">
      <div class="campaigns-haru-eye"></div>
      <div class="campaigns-haru-eye"></div>
    </div>

    <div>
      <h2>Haru</h2>
      <p id="campaignsHaruMessage">
        Aquí puedes crear campañas para promocionar los productos de tu inventario.
      </p>
    </div>
  </section>

  <section class="campaigns-create-card">
    <h2>Crear nueva campaña</h2>

    <%= form_with url: campaigns_create_path, method: :post, local: true, class: "campaigns-form" do %>
      <div class="campaigns-fields">
        <input type="text" name="name" placeholder="Nombre de campaña" class="campaigns-input" required>

        <select name="status" class="campaigns-input">
          <option value="Activa">Activa</option>
          <option value="Pausada">Pausada</option>
          <option value="Planeada">Planeada</option>
        </select>
      </div>

      <button type="submit" class="campaigns-submit">Crear campaña</button>
    <% end %>
  </section>

  <section class="campaigns-list">
    <% if @campaigns.any? %>
      <% @campaigns.each do |campaign| %>
        <article class="campaign-card">
          <div>
            <span class="campaign-status <%= campaign.status.to_s.downcase %>">
              <%= campaign.status.presence || "Sin estado" %>
            </span>

            <h3><%= campaign.name %></h3>

            <p>
              Haru puede ayudarte a convertir esta campaña en anuncios, ideas de contenido y publicaciones.
            </p>
          </div>

          <div class="campaign-actions">
            <%= link_to "Abrir IA", ai_index_path, class: "campaign-btn campaign-btn-blue" %>
            <%= link_to "Eliminar", "/campaigns/delete/#{campaign.id}", class: "campaign-btn campaign-btn-red" %>
          </div>
        </article>
      <% end %>
    <% else %>
      <div class="campaigns-empty">
        <h2>No hay campañas todavía</h2>
        <p>Crea tu primera campaña para empezar a organizar tu marketing digital.</p>
      </div>
    <% end %>
  </section>

  <nav class="campaigns-bottom-nav">
    <%= link_to "Inicio", dashboard_index_path %>
    <%= link_to "Campañas", campaigns_index_path %>
    <%= link_to "Inventario", inventory_index_path %>
    <%= link_to "IA", ai_index_path %>
  </nav>
</div>

<script>
document.addEventListener("turbo:load", function () {
  const message = document.getElementById("campaignsHaruMessage");

  if (!message) return;

  const messages = [
    "Aquí puedes crear campañas para promocionar los productos de tu inventario.",
    "Una campaña puede estar activa, pausada o en planeación.",
    "Después podrás conectar una campaña con Haru para generar anuncios automáticamente.",
    "Usa nombres claros para identificar cada estrategia de marketing.",
    "Más adelante podré recomendar qué campaña activar según tu inventario."
  ];

  let index = 0;

  setInterval(function () {
    index = (index + 1) % messages.length;
    message.style.opacity = "0";

    setTimeout(function () {
      message.textContent = messages[index];
      message.style.opacity = "1";
    }, 300);
  }, 3000);
});
</script>