<!DOCTYPE html>
<html>
  <head>
    <title>AI-Link</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        width: 100%;
        min-height: 100%;
        font-family: Arial, sans-serif;
      }

      a {
        text-decoration: none;
        display: inline-block;
      }

      button {
        cursor: pointer;
      }
    </style>
  </head>

  <body>
    <%= yield %>
  </body>
</html>